# ═══════════════════════════════════════════════════════════════════════════════
# Astro-Bot — environment template
# Copy to .env and fill in secrets. This file is safe to commit.
#
# Profile below: 1h signal cadence (CHECK_INTERVAL_MINUTES=60, ATR_EMA_TIMEFRAME=1h).
# Optional: keep POSITION_CHECK_INTERVAL_MINUTES=15 for more frequent TP/SL / book-profit checks.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Hyperliquid Wallet ────────────────────────────────────────────────────────
HYPERLIQUID_WALLET_ADDRESS=0xYourAgentWalletAddressHere
HYPERLIQUID_PRIVATE_KEY=0xYourAgentWalletPrivateKeyHere

# ── Paper vs Live ─────────────────────────────────────────────────────────────
PAPER_TRADING=true

# ── Multi-user / Postgres (Railway) ───────────────────────────────────────────
# When DATABASE_URL is set, signals + kv_store (positions/equity) use Postgres.
# Each bot service should set a unique BOT_USER_ID so rows stay isolated.
BOT_USER_ID=default
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ── Bot cadence — 1 hour ────────────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=60

SCORE_HISTORY_WINDOW=5
SLOPE_THRESHOLD=0.5
MAX_WEEKLY_TRADES=99

# ── EMA trend filter ──────────────────────────────────────────────────────────
EMA_FILTER=two_way
EMA_PERIOD=20

# Candle timeframe for ATR + EMA and paper-mode intrabar SL/TP.
# Tuning guide:
#   4h  = safer / lower drawdown / fewer trades
#   1h  = balanced (recommended default)
#   15m = aggressive / more trades / higher noise
ATR_EMA_TIMEFRAME=1h

# Force ATR/EMA timeframe to 4h regardless of ATR_EMA_TIMEFRAME
ATR_EMA_FORCE=false

# ── Nakshatra / retrograde ────────────────────────────────────────────────────
NAKSHATRA_FILTER=false
MERCURY_RX_BLOCK=true
SATURN_RX_BLOCK=true

# ── Short-side astro blocks ───────────────────────────────────────────────────
SHORT_BLOCK_JUPITER_URANUS=true
SHORT_BLOCK_MERCURY_RX=true
SHORT_BLOCK_NEW_MOON=true

# ── Risk ──────────────────────────────────────────────────────────────────────
CAPITAL_PCT=1.0
CAPITAL_USDT=100000
RISK_PER_TRADE_PCT=0.01
MAX_DRAWDOWN_HALT_PCT=0.10
MAX_OPEN_BARS=12
RR_RATIO=2.0
ATR_MULTIPLIER=1.5
LEVERAGE=3

# ── Optional Martingale sizing ──────────────────────────────────────────────
# Enabled only in paper mode (PAPER_TRADING=true).
# After consecutive losing paper closes, the next position size multiplier is:
#   MARTINGALE_MULTIPLIER ** martingale_level
MARTINGALE_ENABLED=false
MARTINGALE_MULTIPLIER=2.0
MARTINGALE_MAX_STEPS=5

# ── Size overlays (day-of-month + weekday seasonality) ───────────────────────
SIZE_OVERLAY_ENABLED=true
DAY_MULTIPLIERS=1=1.5,3=1.5,5=1.25,6=1.25,7=1.25,30=1.5,31=1.5
BUY_DAY_MULTIPLIERS=15=1.25
SELL_DAY_MULTIPLIERS=1=1.25,30=1.25,31=1.25
WEEKDAY_MULTIPLIERS=mon=1.05
BUY_WEEKDAY_MULTIPLIERS=sun=1.2

# ── Position monitor (book profit between signal cycles) ──────────────────────
POSITION_CHECK_INTERVAL_MINUTES=15
BOOK_PROFIT_AT_R=0

# ── Asset ─────────────────────────────────────────────────────────────────────
ACTIVE_ASSET=BTC

# ── Logging / local SQLite fallback ───────────────────────────────────────────
LOG_LEVEL=INFO
DB_PATH=logs/signals.db

# ── Swiss Ephemeris (optional files in ./ephe) ────────────────────────────────
EPHE_PATH=./ephe
